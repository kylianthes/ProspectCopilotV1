{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prospect Copilot",
  "version": "0.1.0",
  "identifier": "com.kylian.prospectcopilot",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Prospect Copilot",
        "width": 1280,
        "height": 800,
        "minWidth": 1100,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/prospect-copilot-backend"
    ],
    "icon": [
      "icons/icon.ico"
    ]
  }
}
